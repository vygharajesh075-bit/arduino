int potPin = A0;
int motorPin = 9;
int ledPin = 6;
int buzzerPin = 5;

int potValue = 0;
int speedValue = 0;
int lastSpeed = 0;

void setup() {
  pinMode(motorPin, OUTPUT);
  pinMode(ledPin, OUTPUT);
  pinMode(buzzerPin, OUTPUT);
  Serial.begin(9600);
}

void loop() {
  potValue = analogRead(potPin);
  speedValue = map(potValue, 0, 1023, 0, 255);

  if (speedValue > lastSpeed) {
    for (int i = lastSpeed; i <= speedValue; i++) {
      analogWrite(motorPin, i);
      analogWrite(ledPin, i);
      tone(buzzerPin, 200 + i * 3);
      delay(5);
    }
  } else if (speedValue < lastSpeed) {
    for (int i = lastSpeed; i >= speedValue; i--) {
      analogWrite(motorPin, i);
      analogWrite(ledPin, i);
      tone(buzzerPin, 200 + i * 3);
      delay(5);
    }
  }

  lastSpeed = speedValue;

  Serial.print("Potentiometer: ");
  Serial.print(potValue);
  Serial.print("  Speed: ");
  Serial.println(speedValue);

  if (speedValue == 0) {
    noTone(buzzerPin);
  }

  delay(50);
}
